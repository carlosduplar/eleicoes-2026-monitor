    "economia": {
      "topic_id": "economia",
      "topic_label_pt": "Economia",
      "topic_label_en": "Economy",
      "candidates": {
        "lula": {
          "position_type": "confirmed",
          "stance": "favor",
          "summary_pt": "Lula defendeu a conciliação entre austeridade fiscal para estabilidade econômica e a implementação de amplas políticas de proteção social e combate à fome. Sua gestão priorizou o crescimento do PIB e a diversificação de mercados internacionais para exportações brasileiras.",
          "summary_en": "Lula advocated for balancing fiscal austerity for economic stability with the implementation of broad social protection and anti-hunger policies. His administration prioritized GDP growth and the diversification of international markets for Brazilian exports.",
          "key_actions": [
            "Ajuste das contas públicas e adoção de medidas de austeridade fiscal no primeiro mandato",
            "Implementação de políticas de proteção social e combate à fome",
            "Busca por crescimento econômico através de taxas anuais mais altas do PIB",
            "Diversificação de parceiros comerciais e atuação como promotor de produtos brasileiros em novos mercados"
          ],
          "sources": [
            {
              "type": "news_report",
              "url": "https://pt.wikipedia.org/wiki/Luiz_Inácio_Lula_da_Silva",
