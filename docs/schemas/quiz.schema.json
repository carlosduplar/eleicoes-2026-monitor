{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/quiz.json",
  "title": "Quiz",
  "description": "Questoes do quiz de afinidade politica com posicoes verificadas dos candidatos.",
  "type": "object",
  "required": ["generated_at", "ordered_topics", "topics"],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Versao do schema do quiz (ex: 2.0.0)."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "knowledge_base_version": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp de versao do candidates_positions usado para gerar o quiz."
    },
    "generator_model": {
      "type": "string",
      "description": "Modelo usado para gerar opcoes de quiz."
    },
    "ordered_topics": {
      "type": "array",
      "items": { "type": "string" },
      "description": "IDs dos topicos ordenados por divergence_score decrescente (10-15 topicos).",
      "minItems": 1,
      "maxItems": 15
    },
    "topics": {
      "type": "object",
      "description": "Chave: topic_id. Valor: objeto com questao e opcoes.",
      "additionalProperties": {
        "$ref": "#/definitions/QuizTopic"
      }
    }
  },
  "definitions": {
    "QuizTopic": {
      "type": "object",
      "required": ["divergence_score", "question_pt", "question_en", "options"],
      "properties": {
        "divergence_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Grau de divergencia entre candidatos neste topico (0.0-1.0)."
        },
        "question_pt": {
          "type": "string",
          "description": "Pergunta do quiz em portugues. NAO revela candidatos."
        },
        "question_en": {
          "type": "string",
          "description": "Pergunta do quiz em ingles."
        },
        "topic_label_pt": {
          "type": "string",
          "description": "Rotulo de topico em portugues."
        },
        "topic_label_en": {
          "type": "string",
          "description": "Rotulo de topico em ingles."
        },
        "generation_quality": {
          "type": "object",
          "description": "Metadados de validacao de qualidade da geracao.",
          "properties": {
            "validated": { "type": "boolean" },
            "validator_model": { "type": "string" },
            "validation_date": { "type": "string", "format": "date-time" }
          },
          "additionalProperties": false
        },
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/QuizOption"
          },
          "minItems": 2,
          "maxItems": 6,
          "description": "Opcoes de resposta. Cada opcao corresponde a posicao de um candidato."
        }
      }
    },
    "QuizOption": {
      "type": "object",
      "required": ["id", "text_pt", "text_en", "weight", "candidate_slug", "confidence"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^opt_[a-z]$",
          "description": "ID da opcao (opt_a, opt_b, etc)."
        },
        "text_pt": {
          "type": "string",
          "description": "Texto da opcao em portugues. NAO menciona candidato."
        },
        "text_en": {
          "type": "string",
          "description": "Texto da opcao em ingles."
        },
        "weight": {
          "type": "integer",
          "minimum": -3,
          "maximum": 3,
          "description": "Peso da posicao no espectro: -3 contra forte, 0 neutro, +3 favor forte."
        },
        "candidate_slug": {
          "type": "string",
          "description": "Slug do candidato cuja posicao esta opcao representa. NUNCA exibido na UI durante perguntas."
        },
        "position_type": {
          "type": "string",
          "enum": ["confirmed", "inferred"],
          "description": "Indica se a posicao foi explicitamente declarada (confirmed) ou inferida (inferred)."
        },
        "source_pt": {
          "type": "string",
          "description": "Fonte da declaracao em portugues. Revelada SOMENTE no resultado."
        },
        "source_en": {
          "type": "string",
          "description": "Fonte da declaracao em ingles."
        },
        "source_url": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "URL primaria da fonte da posicao."
        },
        "source_date": {
          "type": ["string", "null"],
          "format": "date",
          "description": "Data da fonte da posicao (YYYY-MM-DD)."
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "description": "Nivel de confianca atribuido a posicao."
        }
      }
    }
  }
}
