{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TSE Data",
  "description": "TSE historical election data and candidate registrations for tracked 2026 pre-candidates. Schema v2.0.0 adds photo_url, declared_assets, ficha_limpa_status, tse_registration_url, and sq_candidato fields.",
  "type": "object",
  "required": ["schema_version", "updated_at", "source", "national_results_2022", "candidates"],
  "properties": {
    "schema_version": { 
      "type": "string",
      "enum": ["2.0.0"]
    },
    "updated_at": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "source_url": { "type": "string", "format": "uri" },
    "disclaimer_pt": { "type": "string" },
    "disclaimer_en": { "type": "string" },
    "national_results_2022": {
      "type": "object",
      "required": ["election", "candidates"],
      "properties": {
        "election": { "type": "string" },
        "election_id": { "type": "integer" },
        "total_candidates": { "type": "integer" },
        "candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "nome": { "type": "string" },
              "numero": { "type": ["integer", "null"] },
              "votos": { "type": ["integer", "null"] },
              "percentual": { "type": ["string", "null"] },
              "eleito": { "type": "boolean" },
              "situacao": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "candidates": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["slug", "full_name", "collected_at"],
        "properties": {
          "slug": { "type": "string" },
          "full_name": { "type": "string" },
          "presidential_2022": {
            "oneOf": [
              { "type": "null" },
              {
                "type": "object",
                "properties": {
                  "nome_urna": { "type": "string" },
                  "numero": { "type": "integer" },
                  "partido": { "type": "string" },
                  "first_round_pct": { "type": "string" },
                  "second_round_pct": { "type": ["string", "null"] },
                  "eleito": { "type": "boolean" }
                }
              }
            ]
          },
          "state_results_2022": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "votos": { "type": ["integer", "null"] },
                "percentual": { "type": ["string", "null"] },
                "eleito": { "type": "boolean" }
              }
            }
          },
          "photo_url": {
            "type": ["string", "null"],
            "description": "TSE CDN photo URL for the candidate",
            "format": "uri"
          },
          "declared_assets": {
            "oneOf": [
              { "type": "null" },
              {
                "type": "object",
                "description": "Candidate's declared assets from 2022 registration",
                "properties": {
                  "total_value": { "type": "number" },
                  "currency": { "type": "string", "enum": ["BRL"] },
                  "count": { "type": "integer" },
                  "assets": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "description": { "type": "string" },
                        "value": { "type": "number" },
                        "type": { "type": "string" }
                      }
                    }
                  }
                }
              }
            ]
          },
          "ficha_limpa_status": {
            "oneOf": [
              { "type": "null" },
              {
                "type": "object",
                "description": "Clean record (ficha limpa) status from TSE",
                "properties": {
                  "is_clean": { "type": "boolean" },
                  "status_code": { "type": ["integer", "null"] },
                  "status_description": { "type": ["string", "null"] }
                }
              }
            ]
          },
          "tse_registration_url": {
            "type": ["string", "null"],
            "description": "Direct link to candidate's TSE registration page",
            "format": "uri"
          },
          "sq_candidato": {
            "type": ["integer", "null"],
            "description": "TSE sequential candidate ID for linking to donor data"
          },
          "no_2022_race": {
            "type": "boolean",
            "description": "True if candidate did not run in 2022 elections"
          },
          "collected_at": { "type": "string", "format": "date-time" },
          "source": { "type": "string" },
          "source_url": { "type": "string" }
        }
      }
    }
  }
}
